.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tip {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.image-section {
  margin: 40rpx 0;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: #FF6B6B;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  background: #f8f8f8;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.example-section {
  margin: 60rpx 0;
  text-align: center;
}

.example-title {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.example-preview {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.example-preview image {
  width: 100%;
  height: 100%;
}

.example-tip {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.footer {
  margin-top: 80rpx;
}

.footer button {
  width: 100%;
}
