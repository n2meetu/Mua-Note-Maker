.header {
  text-align: center;
  padding: 40rpx 0;
}

.title{
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle{
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 语音识别区域 */
.voice-section{
  margin: 40rpx 0;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  text-align: center;
}

.voice-btn{
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: white;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  transition: all 0.3s ease;
}

.voice-btn.recording{
  background: #ff4757;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse{
  0%, 100%{
    transform: scale(1);
    box-shadow: 0 8rpx 20rpx rgba(255,71,87,0.3);
  }
  50%{
    transform: scale(1.05);
    box-shadow: 0 12rpx 30rpx rgba(255,71,87,0.5);
  }
}

.voice-icon{
  font-size: 60rpx;
  display: block;
  margin-bottom: 12rpx;
}

.voice-text{
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.voice-btn.recording .voice-text{
  color: white;
}

/* 语音状态提示 */
.voice-status{
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  text-align: center;
}

/* 识别结果显示 */
.recognized-text{
  margin-top: 30rpx;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: left;
}

.recognized-text .label{
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.recognized-text .content{
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 语音不支持提示 */
.voice-unsupported{
  margin: 40rpx 0;
  padding: 40rpx 32rpx;
  background: #fff3cd;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #ffc107;
}

.unsupported-icon{
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.unsupported-text{
  font-size: 28rpx;
  color: #856404;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.unsupported-tip{
  font-size: 24rpx;
  color: #856404;
  opacity: 0.8;
}

/* 文本输入区域 */
.text-section{
  margin: 60rpx 0;
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.text-label{
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.text-input{
  width: 100%;
  min-height: 500rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f8f8f8;
  font-size: 30rpx;
  line-height: 1.8;
}

.char-count{
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 底部按钮 */
.footer{
  margin-top: 80rpx;
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
}

.footer button{
  flex: 1;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-secondary{
  background-color: #f8f8f8;
  color: #666;
}

.btn-primary{
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 500;
}
