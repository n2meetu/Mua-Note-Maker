<view class="container">
  <view class="header">
    <text class="title">📝 美食笔记生成器</text>
  <text class="subtitle">记录你的拿手好菜</text>
  </view>

  <!-- 语音识别区域 -->
  <view class="voice-section" wx:if="{{voiceSupported}}">
    <button 
      class="voice-btn {{isRecording ? 'recording' : ''}}"
      bindtouchstart="handleVoicePress"
      bindtouchend="handleVoicePress"
    >
      <text class="voice-icon">{{isRecording ? '🎤' : '🎙️'}}</text>
      <text class="voice-text">{{voiceButtonText}}</text>
    </button>
    
    <view class="recognized-text" wx:if="{{recognizedText}}">
      <text class="label">识别结果：</text>
      <text class="content">{{recognizedText}}</text>
    </view>
    
    <view class="voice-status">{{voiceStatusText}}</view>
  </view>
  
  <!-- 语音不支持提示 -->
  <view class="voice-unsupported" wx:else>
    <text class="unsupported-icon">⚠️</text>
    <text class="unsupported-text">{{voiceStatusText}}</text>
    <text class="unsupported-tip">请直接使用下方输入框记录</text>
  </view>

  <!-- 文本输入区域 -->
  <view class="text-section">
    <view class="text-label">手动输入：</view>
    <textarea 
      class="text-input"
      value="{{recordText}}"
      bindinput="onTextInput"
      placeholder="或直接输入做菜步骤..."
      maxlength="500"
    ></textarea>
    <view class="char-count">{{recordText.length}}/500</view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="btn-secondary" bindtap="goBack">返回上一步</button>
    <button class="btn-primary" bindtap="generateNote">生成笔记</button>
  </view>
</view>
