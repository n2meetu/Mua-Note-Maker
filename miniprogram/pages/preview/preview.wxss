.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tip {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.note-section {
  margin: 40rpx 0;
}

.note-block {
  margin-bottom: 32rpx;
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.block-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.note-title {
  min-height: 80rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #fff5f5;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  position: relative;
  transition: all 0.3s;
}

.note-title.editing {
  background: white;
  border: 2rpx solid #FF6B6B;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.2);
}

.note-content {
  min-height: 300rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f5f9ff;
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  position: relative;
  transition: all 0.3s;
}

.note-content.editing {
  background: white;
  border: 2rpx solid #4A90E2;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 226, 0.2);
}

.note-tags {
  min-height: 60rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f0fff4;
  font-size: 28rpx;
  color: #FF6B6B;
  line-height: 1.6;
  position: relative;
  transition: all 0.3s;
}

.note-tags.editing {
  background: white;
  border: 2rpx solid #4CAF50;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.2);
}

.edit-icon {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  font-size: 28rpx;
  opacity: 0.3;
}

.edit-input {
  width: 100%;
  font-size: inherit;
  line-height: inherit;
  background: transparent;
  padding: 0;
}

.title-input {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
}

.content-input {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
}

.tags-input {
  font-size: 28rpx;
  color: #FF6B6B;
}

.loading-section {
  padding: 80rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 32rpx;
  color: #999;
}

.footer {
  margin-top: 60rpx;
  display: flex;
  gap: 20rpx;
}

.footer button {
  flex: 1;
}

.btn-secondary {
  background-color: #f8f8f8;
  color: #666;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

.btn-primary {
  background-color: #FF6B6B;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.tip-section {
  margin-top: 60rpx;
  text-align: center;
}

.tip-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.btn-link {
  background: none;
  border: none;
  color: #FF6B6B;
  font-size: 28rpx;
  padding: 0;
  line-height: normal;
}

.btn-link::after {
  border: none;
}
